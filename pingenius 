<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PinGenius - AI Pinterest Pin Generator</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    },
                    animation: {
                        'spin-slow': 'spin 3s linear infinite',
                    }
                }
            }
        }
    </script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* Custom Scrollbar for aesthetic */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        .fade-in { animation: fadeIn 0.4s ease-in-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 transition-colors duration-200 antialiased overflow-hidden flex flex-col md:flex-row h-screen">

    <!-- Sidebar / Bottom Nav -->
    <nav class="md:w-64 bg-white border-r border-slate-200 flex-shrink-0 flex flex-col fixed bottom-0 w-full md:relative z-40 transition-colors duration-200 dark:bg-slate-800 dark:border-slate-700">
        <div class="p-4 md:p-6 flex items-center gap-2 hidden md:flex border-b border-slate-100 dark:border-slate-700">
            <div class="w-8 h-8 rounded-lg bg-red-500 flex items-center justify-center text-white">
                <i data-lucide="bookmark" class="w-5 h-5 fill-current"></i>
            </div>
            <span class="text-xl font-bold tracking-tight dark:text-white">PinGenius</span>
        </div>
        
        <div class="flex md:flex-col p-2 md:p-4 gap-1 md:gap-2 justify-around md:justify-start overflow-x-auto" id="nav-container">
            <!-- Nav buttons injected via JS -->
        </div>

        <div class="hidden md:block mt-auto p-4 border-t border-slate-100 dark:border-slate-700">
            <div class="bg-slate-100 dark:bg-slate-700 rounded-xl p-4 transition-colors">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-sm font-semibold dark:text-slate-200">Credits</span>
                    <span class="text-sm font-bold text-red-500" id="desktop-credits">5/5</span>
                </div>
                <div class="w-full bg-slate-200 dark:bg-slate-600 rounded-full h-2 mb-3 overflow-hidden">
                    <div class="bg-red-500 h-full rounded-full transition-all duration-300" id="desktop-credits-bar" style="width: 100%"></div>
                </div>
                <button onclick="showPremiumModal()" id="premium-btn-desktop" class="w-full flex items-center justify-center gap-2 text-xs font-semibold bg-gradient-to-r from-amber-400 to-orange-500 text-white py-2 rounded-lg hover:opacity-90 transition-opacity hidden">
                    <i data-lucide="crown" class="w-4 h-4"></i> Go Premium
                </button>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden pb-16 md:pb-0 dark:bg-slate-900 transition-colors">
        <!-- Header -->
        <header class="h-16 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between px-4 md:px-8 flex-shrink-0 z-30 transition-colors">
            <div class="flex items-center gap-2 md:hidden">
                <div class="w-8 h-8 rounded-lg bg-red-500 flex items-center justify-center text-white">
                    <i data-lucide="bookmark" class="w-5 h-5 fill-current"></i>
                </div>
                <span class="font-bold dark:text-white">PinGenius</span>
            </div>
            
            <div class="hidden md:block">
                <h1 class="text-xl font-semibold opacity-90 capitalize dark:text-white" id="header-title">Generator</h1>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="md:hidden flex items-center gap-1 text-sm font-semibold bg-slate-100 dark:bg-slate-700 dark:text-white px-3 py-1.5 rounded-full cursor-pointer transition-colors" onclick="showPremiumModal()">
                    <i data-lucide="sparkles" class="w-4 h-4 text-amber-500"></i> <span id="mobile-credits">5</span>
                </div>
                <button onclick="toggleDarkMode()" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-500 dark:text-slate-400 transition-colors">
                    <i data-lucide="moon" id="theme-icon" class="w-5 h-5"></i>
                </button>
            </div>
        </header>

        <!-- Dynamic View Container -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8">
            <div class="max-w-5xl mx-auto" id="app-content">
                <!-- Content injected via JS -->
            </div>
        </div>
    </main>

    <!-- Premium Modal -->
    <div id="premium-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden opacity-0 transition-opacity duration-300">
        <div class="bg-white dark:bg-slate-800 rounded-2xl max-w-md w-full p-6 shadow-2xl relative transform scale-95 transition-transform duration-300" id="premium-modal-content">
            <button onclick="hidePremiumModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
            <div class="w-16 h-16 bg-amber-100 dark:bg-amber-900/30 rounded-full flex items-center justify-center mx-auto mb-4 text-amber-500">
                <i data-lucide="crown" class="w-8 h-8"></i>
            </div>
            <h2 class="text-2xl font-bold text-center mb-2 dark:text-white">Unlock Unlimited Pins</h2>
            <p class="text-center text-slate-500 dark:text-slate-400 mb-6">You've reached your free daily limit. Upgrade to Premium to keep creating viral content.</p>
            
            <ul class="space-y-3 mb-8 dark:text-slate-200">
                <li class="flex items-center gap-3"><i data-lucide="check" class="w-5 h-5 text-green-500"></i> <span>Unlimited AI Generations</span></li>
                <li class="flex items-center gap-3"><i data-lucide="check" class="w-5 h-5 text-green-500"></i> <span>Auto-publish to Pinterest</span></li>
                <li class="flex items-center gap-3"><i data-lucide="check" class="w-5 h-5 text-green-500"></i> <span>Access to Pro Templates</span></li>
                <li class="flex items-center gap-3"><i data-lucide="check" class="w-5 h-5 text-green-500"></i> <span>Priority Image Generation</span></li>
            </ul>

            <button onclick="hidePremiumModal()" class="w-full bg-gradient-to-r from-red-500 to-rose-600 text-white font-bold py-4 rounded-xl shadow-lg hover:shadow-xl transition-all hover:scale-[1.02]">
                Upgrade for $9.99/mo
            </button>
            <p class="text-center text-xs text-slate-400 mt-4">Cancel anytime. Simulated for demo purposes.</p>
        </div>
    </div>

    <!-- Notification Toast -->
    <div id="toast" class="fixed bottom-20 md:bottom-10 left-1/2 -translate-x-1/2 bg-slate-800 text-white px-6 py-3 rounded-full shadow-lg transition-all duration-300 transform translate-y-20 opacity-0 z-50 flex items-center gap-2">
        <i data-lucide="check-circle" class="w-4 h-4 text-green-400"></i> <span id="toast-msg">Copied!</span>
    </div>

    <!-- Application Logic -->
    <script>
        // --- Configuration ---
        const apiKey = ""; // API key is injected by the environment at runtime
        
        // --- State ---
        let state = {
            activeTab: 'home',
            isDarkMode: false,
            topic: '',
            isGenerating: false,
            loadingStep: '',
            error: '',
            currentResult: null,
            savedPins: [],
            credits: 5
        };

        const TRENDING_TOPICS = {
            "Business": ["Faceless Digital Marketing", "Passive Income Ideas", "Etsy Shop Setup"],
            "Health": ["Somatic Exercises", "High Protein Meal Prep", "Cycle Syncing Workouts"],
            "Fashion": ["Old Money Aesthetic", "Capsule Wardrobe Spring", "Cherry Red Outfits"],
            "Food": ["Matcha Recipes", "Viral Cottage Cheese Bread", "Mocktail Recipes"],
            "Travel": ["Solo Travel Europe", "Hidden Gems in Japan", "Budget Travel Hacks"],
            "AI Tools": ["ChatGPT Prompts for Business", "Midjourney Styles", "AI Video Generators"]
        };

        const TEMPLATES = [
            { name: "Minimal Text", desc: "Clean, elegant, high conversion", style: "bg-slate-100 text-slate-900" },
            { name: "Listicle", desc: "Great for 5-10 step guides", style: "bg-red-50 border-4 border-red-500 text-red-900" },
            { name: "Quote Style", desc: "Inspirational & aesthetic", style: "bg-black text-white italic font-serif" },
            { name: "Before/After", desc: "Perfect for fitness & DIY", style: "bg-gradient-to-r from-slate-200 to-slate-400 text-slate-900" },
        ];

        // --- API Helpers ---
        const fetchWithRetry = async (url, options, retries = 5) => {
            const delays = [1000, 2000, 4000, 8000, 16000];
            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, options);
                    if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                    return await response.json();
                } catch (error) {
                    if (i === retries - 1) throw error;
                    await new Promise(res => setTimeout(res, delays[i]));
                }
            }
        };

        const generatePinData = async (topic) => {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: `Create Pinterest pin content for the topic: "${topic}". Make it viral, highly engaging, and SEO optimized.` }] }],
                systemInstruction: { parts: [{ text: "You are an expert Pinterest strategist and copywriter. Generate content optimized for clicks and saves." }] },
                generationConfig: {
                    responseMimeType: "application/json",
                    responseSchema: {
                        type: "OBJECT",
                        properties: {
                            title: { type: "STRING", description: "Catchy, click-worthy Pinterest title (max 60 chars)" },
                            description: { type: "STRING", description: "SEO optimized pin description (2-3 sentences), engaging and descriptive." },
                            hashtags: { type: "ARRAY", items: { type: "STRING" }, description: "10 trending hashtags without the # symbol" },
                            imagePrompt: { type: "STRING", description: "A highly detailed prompt for an AI image generator to create an aesthetic, vertical background image related to the topic. Do NOT include text in the prompt. Make it visually appealing, modern, and suitable for a Pinterest background." },
                            pinOverlayText: { type: "STRING", description: "Very short, punchy text to overlay on the center of the image (max 4-6 words). E.g., '10 Tips for X' or 'How to Y'." }
                        },
                        required: ["title", "description", "hashtags", "imagePrompt", "pinOverlayText"]
                    }
                }
            };
            const data = await fetchWithRetry(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            const textResponse = data.candidates?.[0]?.content?.parts?.[0]?.text;
            if (!textResponse) throw new Error("Failed to generate text content.");
            return JSON.parse(textResponse);
        };

        const generateImage = async (prompt) => {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`;
            const payload = {
                instances: { prompt: `${prompt}. High quality, vertical aspect ratio, beautiful lighting, aesthetic.` },
                parameters: { sampleCount: 1, aspectRatio: "9:16" }
            };
            const data = await fetchWithRetry(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            const base64 = data.predictions?.[0]?.bytesBase64Encoded;
            if (!base64) throw new Error("Failed to generate image.");
            return `data:image/png;base64,${base64}`;
        };

        // --- UI Rendering Logic ---

        function updateNavigation() {
            const navContainer = document.getElementById('nav-container');
            const navItems = [
                { id: 'home', icon: 'wand-2', label: 'Generator' },
                { id: 'trending', icon: 'trending-up', label: 'Trending Ideas' },
                { id: 'templates', icon: 'layout-template', label: 'Templates' },
                { id: 'saved', icon: 'bookmark', label: 'Saved Pins' }
            ];

            navContainer.innerHTML = navItems.map(item => `
                <button onclick="switchTab('${item.id}')" class="flex flex-col md:flex-row items-center gap-1 md:gap-3 p-2 md:px-4 md:py-3 rounded-xl transition-all duration-200 flex-1 md:flex-none ${state.activeTab === item.id ? 'text-red-600 bg-red-50 dark:bg-red-500/10 dark:text-red-400 font-bold' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 font-medium'}">
                    <i data-lucide="${item.icon}" class="w-5 h-5"></i>
                    <span class="text-[10px] md:text-sm">${item.label}</span>
                </button>
            `).join('');
            
            document.getElementById('header-title').innerText = state.activeTab === 'home' ? 'Generator' : state.activeTab.replace('-', ' ');
            lucide.createIcons();
        }

        function updateCreditsUI() {
            document.getElementById('desktop-credits').innerText = `${state.credits}/5`;
            document.getElementById('desktop-credits-bar').style.width = `${(state.credits/5)*100}%`;
            document.getElementById('mobile-credits').innerText = state.credits;
            
            if (state.credits < 5) {
                document.getElementById('premium-btn-desktop').classList.remove('hidden');
            }
        }

        function switchTab(tabId) {
            state.activeTab = tabId;
            updateNavigation();
            renderContent();
        }

        function toggleDarkMode() {
            state.isDarkMode = !state.isDarkMode;
            if (state.isDarkMode) {
                document.documentElement.classList.add('dark');
                document.getElementById('theme-icon').setAttribute('data-lucide', 'sun');
            } else {
                document.documentElement.classList.remove('dark');
                document.getElementById('theme-icon').setAttribute('data-lucide', 'moon');
            }
            lucide.createIcons();
        }

        function showPremiumModal() {
            const modal = document.getElementById('premium-modal');
            const content = document.getElementById('premium-modal-content');
            modal.classList.remove('hidden');
            // Trigger reflow
            void modal.offsetWidth;
            modal.classList.remove('opacity-0');
            content.classList.remove('scale-95');
        }

        function hidePremiumModal() {
            const modal = document.getElementById('premium-modal');
            const content = document.getElementById('premium-modal-content');
            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-msg').innerText = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // --- Core Generator Logic ---

        async function handleGenerate() {
            const topicInput = document.getElementById('topic-input');
            state.topic = topicInput ? topicInput.value : state.topic;
            
            if (!state.topic.trim()) {
                state.error = "Please enter a topic first.";
                renderContent();
                return;
            }
            if (state.credits <= 0) {
                showPremiumModal();
                return;
            }

            state.error = '';
            state.isGenerating = true;
            state.currentResult = null;
            renderContent(); // Render loading state

            try {
                state.loadingStep = 'Analyzing topic & writing copy...';
                renderContent();
                
                const textData = await generatePinData(state.topic);
                
                state.loadingStep = 'Designing aesthetic background image...';
                renderContent();
                
                const imageUrl = await generateImage(textData.imagePrompt);

                state.currentResult = {
                    ...textData,
                    imageUrl,
                    id: Date.now().toString(),
                    createdAt: new Date().toISOString()
                };
                
                state.credits--;
                updateCreditsUI();
            } catch (err) {
                console.error(err);
                state.error = 'Oops, something went wrong while generating. Please try again.';
            } finally {
                state.isGenerating = false;
                state.loadingStep = '';
                renderContent();
            }
        }

        function copyToClipboard(text, type) {
            navigator.clipboard.writeText(text).then(() => {
                showToast(`Copied ${type}!`);
            }).catch(() => {
                // Fallback
                const textArea = document.createElement("textarea");
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                showToast(`Copied ${type}!`);
            });
        }

        function saveCurrentPin() {
            if (state.currentResult && !state.savedPins.find(p => p.id === state.currentResult.id)) {
                state.savedPins.unshift(state.currentResult);
                showToast("Pin saved!");
                renderContent(); // Re-render to update save button state
            }
        }

        function downloadCanvas() {
            const canvas = document.getElementById('pin-canvas');
            if (!canvas) return;
            const dataUrl = canvas.toDataURL("image/png");
            const link = document.createElement('a');
            link.download = `PinGenius-${state.currentResult.pinOver